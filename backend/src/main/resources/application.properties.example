spring.application.name=backend

# Base de datos MariaDB
spring.datasource.url=${SPRING_DATASOURCE_URL:jdbc:mariadb://localhost:3306/gpbikes_mods}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:root}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:}

# Hibernate Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MariaDBDialect
spring.sql.init.mode=always

# Puerto del servidor
server.port=8080

# Discord OAuth2
discord.client.id=${DISCORD_CLIENT_ID:}
discord.client.secret=${DISCORD_CLIENT_SECRET:}
discord.redirect.uri=${DISCORD_REDIRECT_URI:http://localhost:8080/api/auth/discord/callback}

# Frontend URL
frontend.url=${FRONTEND_URL:http://localhost:4200}

# Carpeta de imagenes disponibles para el admin
mods.images.directory=${MODS_IMAGES_DIRECTORY:../frontend/public/home}
mods.files.directory=${MODS_FILES_DIRECTORY:/data/mods-files}

# JWT
jwt.secret=${JWT_SECRET:}

# Email configurations (SMTP)
spring.mail.host=${SPRING_MAIL_HOST:smtp.gmail.com}
spring.mail.port=${SPRING_MAIL_PORT:587}
spring.mail.username=${SPRING_MAIL_USERNAME:}
spring.mail.password=${SPRING_MAIL_PASSWORD:}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
